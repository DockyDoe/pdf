# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://admin:password@localhost:27017/pdf-utility?authSource=admin

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Clerk Authentication
CLERK_SECRET_KEY=sk_test_placeholder_replace_with_real_key
CLERK_PUBLISHABLE_KEY=pk_test_placeholder_replace_with_real_key

# Google Gemini API
GEMINI_API_KEY=placeholder_replace_with_real_key

# File Storage
UPLOAD_DIR=uploads
MAX_FILE_SIZE=50000000
ALLOWED_FILE_TYPES=pdf,doc,docx,ppt,pptx,xls,xlsx,jpg,jpeg,png

# WebSocket
WS_PORT=5001

# Security
JWT_SECRET=your_jwt_secret_change_in_production_123456789
CORS_ORIGIN=http://localhost:3000

# LibreOffice (for file conversion)
LIBREOFFICE_PATH=/usr/bin/libreoffice

# Logging
LOG_LEVEL=info